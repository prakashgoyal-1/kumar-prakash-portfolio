# Copy to .env and fill in all values before running docker compose up.
# Generate secrets: openssl rand -hex 32

# === DATABASE ===
DATABASE_URL=postgresql+asyncpg://postgres:password@postgres:5432/portfolio
POSTGRES_DB=portfolio
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password

# === REDIS ===
REDIS_URL=redis://redis:6379/0

# === JWT (generate secret: openssl rand -hex 32) ===
JWT_SECRET=change-me-to-a-64-char-random-string-minimum-32-chars-required
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# === GOOGLE OAUTH (from Google Cloud Console) ===
# Used by BOTH backend (token verification) and frontend
# (VITE_GOOGLE_CLIENT_ID below) — MUST be the same value.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# === APP ===
FRONTEND_URL=http://localhost:5173

# === S3 / MinIO ===
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=portfolio
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# === SMTP (Gmail: use App Password, not your main password) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM_EMAIL=your@email.com
ADMIN_EMAIL=your@email.com

# === FRONTEND (Vite reads at BUILD time — must start with VITE_) ===
VITE_API_URL=http://localhost:8000
# Same value as GOOGLE_CLIENT_ID above
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com